import os
import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import torch

def tensor_to_uint8_img(x):
    x = x.detach().clamp(0, 1).cpu().squeeze(0)
    x = x.permute(1, 2, 0).numpy()
    x = (x * 255.0).round().astype(np.uint8)
    return x

def pil_to_uint8(img):
    return np.array(img.convert("RGB"))

def calc_psnr_np(img1, img2):
    img1 = img1.astype(np.float32)
    img2 = img2.astype(np.float32)
    mse = np.mean((img1 - img2) ** 2)
    if mse <= 1e-10:
        return 99.0
    return 20 * np.log10(255.0 / np.sqrt(mse))

def bicubic_upsample_from_hr(hr_pil, scale):
    w, h = hr_pil.size
    lr = hr_pil.resize((max(1, w // scale), max(1, h // scale)), Image.BICUBIC)
    bicubic = lr.resize((w, h), Image.BICUBIC)
    return lr, bicubic

def rgb_to_gray_np(img):
    if img.ndim == 2:
        return img.astype(np.float32)
    return (0.299 * img[..., 0] + 0.587 * img[..., 1] + 0.114 * img[..., 2]).astype(np.float32)

def find_best_crop(img_np, crop_size=128, stride=32):
    h, w = img_np.shape[:2]
    crop_size = min(crop_size, h, w)
    if crop_size < 32:
        return 0, 0, min(w, 32), min(h, 32)

    gray = rgb_to_gray_np(img_np)
    best_score = -1
    best_box = (0, 0, crop_size, crop_size)

    y_positions = list(range(0, max(1, h - crop_size + 1), stride))
    x_positions = list(range(0, max(1, w - crop_size + 1), stride))
    if not y_positions:
        y_positions = [0]
    if not x_positions:
        x_positions = [0]
    if y_positions[-1] != h - crop_size:
        y_positions.append(max(0, h - crop_size))
    if x_positions[-1] != w - crop_size:
        x_positions.append(max(0, w - crop_size))

    for y in y_positions:
        for x in x_positions:
            patch = gray[y:y + crop_size, x:x + crop_size]
            if patch.shape[0] < crop_size or patch.shape[1] < crop_size:
                continue
            score = np.abs(np.diff(patch, axis=1)).mean() + np.abs(np.diff(patch, axis=0)).mean()
            if score > best_score:
                best_score = score
                best_box = (x, y, crop_size, crop_size)

    return best_box

@torch.no_grad()
def save_epoch_visual(epoch_num, sample_path, save_dir, crop_size=128, prefix="epoch"):
    model.eval()

    hr_pil = Image.open(sample_path).convert("RGB")
    hr_np = pil_to_uint8(hr_pil)

    lr_pil, bicubic_pil = bicubic_upsample_from_hr(hr_pil, SCALE)
    lr_tensor = transforms.ToTensor()(lr_pil).unsqueeze(0).to(DEVICE)

    with torch.amp.autocast(device_type='cuda', enabled=(USE_AMP and torch.cuda.is_available())):
        sr_tensor = model(lr_tensor)

    sr_np = tensor_to_uint8_img(sr_tensor)

    h, w = hr_np.shape[:2]
    sr_np = np.array(Image.fromarray(sr_np).resize((w, h), Image.BICUBIC))
    bicubic_np = np.array(bicubic_pil.resize((w, h), Image.BICUBIC))

    psnr_b = calc_psnr_np(bicubic_np, hr_np)
    psnr_s = calc_psnr_np(sr_np, hr_np)

    x, y, cw, ch = find_best_crop(hr_np, crop_size=crop_size, stride=max(16, crop_size // 4))
    bic_crop = bicubic_np[y:y+ch, x:x+cw]
    sr_crop = sr_np[y:y+ch, x:x+cw]
    hr_crop = hr_np[y:y+ch, x:x+cw]

    fig, axes = plt.subplots(2, 3, figsize=(14, 8))

    axes[0, 0].imshow(bicubic_np)
    axes[0, 0].set_title(f"Bicubic | {psnr_b:.2f} dB")
    axes[0, 1].imshow(sr_np)
    axes[0, 1].set_title(f"FSRCNN | {psnr_s:.2f} dB")
    axes[0, 2].imshow(hr_np)
    axes[0, 2].set_title("HR")

    axes[1, 0].imshow(bic_crop)
    axes[1, 0].set_title("Zoom Bicubic")
    axes[1, 1].imshow(sr_crop)
    axes[1, 1].set_title("Zoom FSRCNN")
    axes[1, 2].imshow(hr_crop)
    axes[1, 2].set_title("Zoom HR")

    for ax in axes.ravel():
        ax.axis("off")

    basename = os.path.basename(sample_path)
    fig.suptitle(f"{prefix.capitalize()} {epoch_num} | {basename}", fontsize=15)
    plt.tight_layout()

    os.makedirs(save_dir, exist_ok=True)
    out_path = os.path.join(save_dir, f"{prefix}_{epoch_num:03d}_comparison.png")
    plt.savefig(out_path, dpi=140, bbox_inches="tight")
    plt.close(fig)

    print(f"Saved visualization: {out_path}")
    return out_path, psnr_b, psnr_s


# =========================
# 6) 训练（按块训练 + 自动续训）
# =========================
start_epoch, best_psnr, history = load_checkpoint_if_exists()
end_epoch = start_epoch + EPOCHS_THIS_RUN

for epoch in range(start_epoch, end_epoch):
    print(f"\nEpoch [{epoch + 1}/{end_epoch}]")

    epoch_train_paths = list(train_paths)
    random.Random(SEED + epoch).shuffle(epoch_train_paths)
    train_chunks = make_chunks(epoch_train_paths, TRAIN_CHUNK_SIZE)

    chunk_losses = []
    for chunk_idx, chunk_paths in enumerate(train_chunks, start=1):
        print(f"  -> Chunk [{chunk_idx}/{len(train_chunks)}], images: {len(chunk_paths)}")

        chunk_dataset = SRDataset(
            chunk_paths,
            patch_size=PATCH_SIZE,
            scale=SCALE,
            training=True,
        )
        chunk_loader = DataLoader(
            chunk_dataset,
            batch_size=BATCH_SIZE,
            shuffle=True,
            num_workers=NUM_WORKERS,
            pin_memory=PIN_MEMORY,
            collate_fn=safe_collate,
            drop_last=False,
        )

        chunk_loss = train_one_epoch_on_chunk(
            model, chunk_loader, criterion, optimizer, scaler, DEVICE
        )

        if chunk_loss is not None:
            chunk_losses.append(chunk_loss)
            print(f"     chunk_loss = {chunk_loss:.6f}")
        else:
            print("     this chunk has no valid samples, skipped.")

        del chunk_dataset, chunk_loader
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()

    train_loss = float(np.mean(chunk_losses)) if chunk_losses else None
    val_loss, val_psnr_model, val_psnr_bicubic = validate(model, val_loader, criterion, DEVICE)

    history["train_loss"].append(np.nan if train_loss is None else train_loss)
    history["val_loss"].append(np.nan if val_loss is None else val_loss)
    history["val_psnr_model"].append(np.nan if val_psnr_model is None else val_psnr_model)
    history["val_psnr_bicubic"].append(np.nan if val_psnr_bicubic is None else val_psnr_bicubic)

    if val_psnr_model is not None:
        scheduler.step(val_psnr_model)

    current_lr = optimizer.param_groups[0]["lr"]
    print(f"Train Loss:    {train_loss if train_loss is not None else 'N/A'}")
    print(f"Val Loss:      {val_loss if val_loss is not None else 'N/A'}")
    print(f"Bicubic PSNR:  {val_psnr_bicubic if val_psnr_bicubic is not None else 'N/A'}")
    print(f"FSRCNN  PSNR:  {val_psnr_model if val_psnr_model is not None else 'N/A'}")
    print(f"Current LR:    {current_lr:.8f}")

    # ===== 保存 checkpoint =====
    ckpt = {
        "epoch": epoch + 1,
        "model_state_dict": model.state_dict(),
        "optimizer_state_dict": optimizer.state_dict(),
        "scheduler_state_dict": scheduler.state_dict(),
        "best_psnr": best_psnr,
        "history": history,
        "config": {
            "scale": SCALE,
            "patch_size": PATCH_SIZE,
            "batch_size": BATCH_SIZE,
            "epochs_this_run": EPOCHS_THIS_RUN,
            "lr": LR,
            "train_chunk_size": TRAIN_CHUNK_SIZE,
        },
    }
    torch.save(ckpt, os.path.join(SAVE_DIR, "fsrcnn_checkpoint.pth"))

    # ===== 每个 epoch 都保存 latest model =====
    torch.save(model.state_dict(), os.path.join(SAVE_DIR, "fsrcnn_last.pth"))

    # ===== 判断是否刷新 best =====
    is_new_best = False
    if val_psnr_model is not None and val_psnr_model > best_psnr:
        best_psnr = val_psnr_model
        torch.save(model.state_dict(), os.path.join(SAVE_DIR, "fsrcnn_best.pth"))
        is_new_best = True
        print("Best model saved.")

    # ===== 每个 epoch 保存一张固定样本对比图到 epoch_compare =====
    if len(val_paths) > 0:
        sample_path = val_paths[0]
    else:
        sample_path = train_paths[0]

    save_epoch_visual(
        epoch_num=epoch + 1,
        sample_path=sample_path,
        save_dir=EPOCH_VIS_DIR,
        crop_size=128,
        prefix="epoch"
    )

    # ===== 如果这一轮刷新了 best，也额外保存到 best_epoch_compare =====
    if is_new_best:
        save_epoch_visual(
            epoch_num=epoch + 1,
            sample_path=sample_path,
            save_dir=BEST_VIS_DIR,
            crop_size=128,
            prefix="best_epoch"
        )

save_history_plot(history, os.path.join(SAVE_DIR, "training_curves.png"))
torch.save(model.state_dict(), os.path.join(SAVE_DIR, "fsrcnn_last.pth"))
print("Training finished.")
print("Best PSNR:", best_psnr if best_psnr > -float("inf") else "N/A")


