import os
import numpy as np
import matplotlib.pyplot as plt
from PIL import Image
import torch

best_model_path = os.path.join(SAVE_DIR, "fsrcnn_best.pth")
last_model_path = os.path.join(SAVE_DIR, "fsrcnn_last.pth")

if os.path.exists(last_model_path):
    model.load_state_dict(torch.load(last_model_path, map_location=DEVICE))
    model.eval()
    print("Last model loaded for visualization.")
elif os.path.exists(best_model_path):
    model.load_state_dict(torch.load(best_model_path, map_location=DEVICE))
    model.eval()
    print("Last model not found, loaded best model instead.")
else:
    raise FileNotFoundError("没有找到可用模型权重。")

def tensor_to_uint8_img(x):
    x = x.detach().clamp(0, 1).cpu().squeeze(0)
    x = x.permute(1, 2, 0).numpy()
    x = (x * 255.0).round().astype(np.uint8)
    return x

def pil_to_uint8(img):
    return np.array(img.convert("RGB"))

def rgb_to_gray_np(img):
    if img.ndim == 2:
        return img.astype(np.float32)
    return (0.299 * img[..., 0] + 0.587 * img[..., 1] + 0.114 * img[..., 2]).astype(np.float32)

def edge_strength_score(img_np):
    gray = rgb_to_gray_np(img_np)
    gx = np.abs(np.diff(gray, axis=1)).mean()
    gy = np.abs(np.diff(gray, axis=0)).mean()
    return float(gx + gy)

def find_best_crop(img_np, crop_size=128, stride=32):
    h, w = img_np.shape[:2]
    crop_size = min(crop_size, h, w)
    if crop_size < 32:
        return 0, 0, min(w, 32), min(h, 32)

    gray = rgb_to_gray_np(img_np)
    best_score = -1
    best_box = (0, 0, crop_size, crop_size)

    y_positions = list(range(0, max(1, h - crop_size + 1), stride))
    x_positions = list(range(0, max(1, w - crop_size + 1), stride))
    if not y_positions:
        y_positions = [0]
    if not x_positions:
        x_positions = [0]
    if y_positions[-1] != h - crop_size:
        y_positions.append(max(0, h - crop_size))
    if x_positions[-1] != w - crop_size:
        x_positions.append(max(0, w - crop_size))

    for y in y_positions:
        for x in x_positions:
            patch = gray[y:y + crop_size, x:x + crop_size]
            if patch.shape[0] < crop_size or patch.shape[1] < crop_size:
                continue
            score = np.abs(np.diff(patch, axis=1)).mean() + np.abs(np.diff(patch, axis=0)).mean()
            if score > best_score:
                best_score = score
                best_box = (x, y, crop_size, crop_size)

    return best_box

def add_crop_box(ax, box, color="yellow", linewidth=2):
    from matplotlib.patches import Rectangle
    x, y, w, h = box
    rect = Rectangle((x, y), w, h, fill=False, edgecolor=color, linewidth=linewidth)
    ax.add_patch(rect)

def bicubic_upsample_from_hr(hr_pil, scale):
    w, h = hr_pil.size
    lr = hr_pil.resize((max(1, w // scale), max(1, h // scale)), Image.BICUBIC)
    bicubic = lr.resize((w, h), Image.BICUBIC)
    return lr, bicubic

def calc_psnr_np(img1, img2):
    img1 = img1.astype(np.float32)
    img2 = img2.astype(np.float32)
    mse = np.mean((img1 - img2) ** 2)
    if mse <= 1e-10:
        return 99.0
    return 20 * np.log10(255.0 / np.sqrt(mse))

@torch.no_grad()
def infer_sr_from_hr_pil(hr_pil, model, device, scale):
    hr_np = pil_to_uint8(hr_pil)
    _, bicubic_pil = bicubic_upsample_from_hr(hr_pil, scale)

    lr_pil = hr_pil.resize(
        (max(1, hr_pil.size[0] // scale), max(1, hr_pil.size[1] // scale)),
        Image.BICUBIC
    )
    lr_tensor = transforms.ToTensor()(lr_pil).unsqueeze(0).to(device)

    with torch.amp.autocast(device_type='cuda', enabled=(USE_AMP and torch.cuda.is_available())):
        sr_tensor = model(lr_tensor)

    sr_np = tensor_to_uint8_img(sr_tensor)

    h, w = hr_np.shape[:2]
    sr_np = np.array(Image.fromarray(sr_np).resize((w, h), Image.BICUBIC))
    bicubic_np = np.array(bicubic_pil.resize((w, h), Image.BICUBIC))

    psnr_bicubic = calc_psnr_np(bicubic_np, hr_np)
    psnr_fsrcnn = calc_psnr_np(sr_np, hr_np)

    return {
        "hr": hr_np,
        "bicubic": bicubic_np,
        "sr": sr_np,
        "psnr_bicubic": psnr_bicubic,
        "psnr_fsrcnn": psnr_fsrcnn,
    }

def collect_candidate_visuals(paths, num_candidates=16):
    candidates = []
    sampled = list(paths[:min(len(paths), num_candidates)])
    if len(paths) > num_candidates:
        step = max(1, len(paths) // num_candidates)
        sampled = [paths[i] for i in range(0, len(paths), step)][:num_candidates]

    for p in sampled:
        try:
            hr_pil = Image.open(p).convert("RGB")
            result = infer_sr_from_hr_pil(hr_pil, model, DEVICE, SCALE)

            detail_score = edge_strength_score(result["hr"])
            gain_score = result["psnr_fsrcnn"] - result["psnr_bicubic"]
            total_score = detail_score + gain_score * 20.0

            candidates.append({
                "path": p,
                "result": result,
                "detail_score": detail_score,
                "gain_score": gain_score,
                "total_score": total_score,
            })
        except Exception as e:
            print(f"Skip visualization sample due to error: {p} | {e}")

    candidates = sorted(candidates, key=lambda x: x["total_score"], reverse=True)
    return candidates

def show_and_save_visuals(candidates, num_show=4, crop_size=128):
    if len(candidates) == 0:
        print("No valid visualization candidates found.")
        return

    os.makedirs(SAVE_DIR, exist_ok=True)
    chosen = candidates[:min(num_show, len(candidates))]

    # 单张图：保持清晰，但不要大到离谱
    for row_idx, item in enumerate(chosen, start=1):
        p = item["path"]
        res = item["result"]
        hr = res["hr"]
        bicubic = res["bicubic"]
        sr = res["sr"]
        psnr_b = res["psnr_bicubic"]
        psnr_s = res["psnr_fsrcnn"]

        x, y, cw, ch = find_best_crop(hr, crop_size=crop_size, stride=max(16, crop_size // 4))

        hr_crop = hr[y:y+ch, x:x+cw]
        bic_crop = bicubic[y:y+ch, x:x+cw]
        sr_crop = sr[y:y+ch, x:x+cw]

        single_fig, axes = plt.subplots(2, 3, figsize=(14, 8))

        axes[0, 0].imshow(bicubic)
        axes[0, 0].set_title(f"Bicubic | {psnr_b:.2f} dB", fontsize=13)
        add_crop_box(axes[0, 0], (x, y, cw, ch))

        axes[0, 1].imshow(sr)
        axes[0, 1].set_title(f"FSRCNN | {psnr_s:.2f} dB", fontsize=13)
        add_crop_box(axes[0, 1], (x, y, cw, ch))

        axes[0, 2].imshow(hr)
        axes[0, 2].set_title("HR (Ground Truth)", fontsize=13)
        add_crop_box(axes[0, 2], (x, y, cw, ch))

        axes[1, 0].imshow(bic_crop)
        axes[1, 0].set_title("Zoomed Bicubic", fontsize=13)

        axes[1, 1].imshow(sr_crop)
        axes[1, 1].set_title("Zoomed FSRCNN", fontsize=13)

        axes[1, 2].imshow(hr_crop)
        axes[1, 2].set_title("Zoomed HR", fontsize=13)

        for ax in axes.ravel():
            ax.axis("off")

        basename = os.path.basename(p)
        single_fig.suptitle(
            f"{basename}\nGain: {psnr_s - psnr_b:.2f} dB",
            fontsize=15
        )
        plt.tight_layout()
        if SAVE_INDIVIDUAL_VIS:
            single_path = os.path.join(SAVE_DIR, f"vis_single_{row_idx:02d}.png")
            plt.savefig(single_path, dpi=150, bbox_inches="tight")
        plt.show()
        plt.close(single_fig)

    # 总览图：专门控制大小，避免本地打开纯白
    grid_rows = len(chosen)
    fig, axes = plt.subplots(grid_rows, 6, figsize=(15, 3.8 * grid_rows))
    if grid_rows == 1:
        axes = np.expand_dims(axes, axis=0)

    for row_idx, item in enumerate(chosen):
        p = item["path"]
        res = item["result"]
        hr = res["hr"]
        bicubic = res["bicubic"]
        sr = res["sr"]
        psnr_b = res["psnr_bicubic"]
        psnr_s = res["psnr_fsrcnn"]

        x, y, cw, ch = find_best_crop(hr, crop_size=crop_size, stride=max(16, crop_size // 4))

        hr_crop = hr[y:y+ch, x:x+cw]
        bic_crop = bicubic[y:y+ch, x:x+cw]
        sr_crop = sr[y:y+ch, x:x+cw]

        row_axes = axes[row_idx]

        row_axes[0].imshow(bicubic)
        add_crop_box(row_axes[0], (x, y, cw, ch))
        row_axes[0].set_title(f"Bicubic\n{psnr_b:.2f} dB", fontsize=10)
        row_axes[0].axis("off")

        row_axes[1].imshow(sr)
        add_crop_box(row_axes[1], (x, y, cw, ch))
        row_axes[1].set_title(f"FSRCNN\n{psnr_s:.2f} dB", fontsize=10)
        row_axes[1].axis("off")

        row_axes[2].imshow(hr)
        add_crop_box(row_axes[2], (x, y, cw, ch))
        row_axes[2].set_title("HR", fontsize=10)
        row_axes[2].axis("off")

        row_axes[3].imshow(bic_crop)
        row_axes[3].set_title("Zoom Bicubic", fontsize=10)
        row_axes[3].axis("off")

        row_axes[4].imshow(sr_crop)
        row_axes[4].set_title("Zoom FSRCNN", fontsize=10)
        row_axes[4].axis("off")

        row_axes[5].imshow(hr_crop)
        row_axes[5].set_title("Zoom HR", fontsize=10)
        row_axes[5].axis("off")

    plt.tight_layout()
    grid_path = os.path.join(SAVE_DIR, "visual_comparison_grid_safe_clear.png")
    plt.savefig(grid_path, dpi=120, bbox_inches="tight")
    plt.show()
    plt.close(fig)

    print(f"Saved safer clear comparison grid to: {grid_path}")

# 更稳一点，避免导出总图过大
vis_num_show = min(4, VIS_NUM_SAMPLES) if 'VIS_NUM_SAMPLES' in globals() else 4
vis_candidates = min(16, VIS_CANDIDATES) if 'VIS_CANDIDATES' in globals() else 16
vis_crop = VIS_CROP_SIZE if 'VIS_CROP_SIZE' in globals() else 128

vis_source_paths = list(val_paths) if len(val_paths) > 0 else list(train_paths[:vis_candidates])
candidates = collect_candidate_visuals(vis_source_paths, num_candidates=vis_candidates)
show_and_save_visuals(candidates, num_show=vis_num_show, crop_size=vis_crop)


