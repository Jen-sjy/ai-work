# 5) 工具函数
# =========================
def calc_psnr(sr, hr):
    mse = torch.mean((sr - hr) ** 2)
    if mse <= 1e-12:
        return torch.tensor(100.0)
    return 10 * torch.log10(1.0 / mse)


def train_one_epoch_on_chunk(model, loader, criterion, optimizer, scaler, device):
    model.train()
    running_loss = 0.0
    valid_steps = 0

    pbar = tqdm(loader, desc="Training chunk", leave=False)
    for batch in pbar:
        if batch is None:
            continue

        lr_img, hr_img, _ = batch
        lr_img = lr_img.to(device, non_blocking=True)
        hr_img = hr_img.to(device, non_blocking=True)

        optimizer.zero_grad(set_to_none=True)

        with torch.amp.autocast('cuda', enabled=USE_AMP):
            sr_img = model(lr_img)
            loss = criterion(sr_img, hr_img)

        scaler.scale(loss).backward()
        scaler.unscale_(optimizer)
        torch.nn.utils.clip_grad_norm_(model.parameters(), MAX_GRAD_NORM)
        scaler.step(optimizer)
        scaler.update()

        running_loss += loss.item()
        valid_steps += 1
        pbar.set_postfix(loss=f"{loss.item():.4f}")

    if valid_steps == 0:
        return None
    return running_loss / valid_steps


@torch.no_grad()
def validate(model, loader, criterion, device):
    model.eval()
    running_loss = 0.0
    running_psnr_model = 0.0
    running_psnr_bicubic = 0.0
    valid_steps = 0

    for batch in tqdm(loader, desc="Validating", leave=False):
        if batch is None:
            continue

        lr_img, hr_img, _ = batch
        lr_img = lr_img.to(device, non_blocking=True)
        hr_img = hr_img.to(device, non_blocking=True)

        with torch.amp.autocast('cuda', enabled=USE_AMP):
            sr_img = model(lr_img)

        sr_img = torch.clamp(sr_img, 0.0, 1.0)
        loss = criterion(sr_img, hr_img)

        running_loss += loss.item()
        running_psnr_model += calc_psnr(sr_img, hr_img).item()
        running_psnr_bicubic += calc_psnr(lr_img, hr_img).item()
        valid_steps += 1

    if valid_steps == 0:
        return None, None, None

    return (
        running_loss / valid_steps,
        running_psnr_model / valid_steps,
        running_psnr_bicubic / valid_steps,
    )


def save_history_plot(history, save_path):
    fig = plt.figure(figsize=(12, 4), dpi=180)

    ax1 = fig.add_subplot(1, 2, 1)
    ax1.plot(history["train_loss"], label="Train Loss")
    ax1.plot(history["val_loss"], label="Val Loss")
    ax1.set_title("Loss Curve")
    ax1.set_xlabel("Epoch")
    ax1.set_ylabel("Loss")
    ax1.legend()

    ax2 = fig.add_subplot(1, 2, 2)
    ax2.plot(history["val_psnr_bicubic"], label="Bicubic PSNR")
    ax2.plot(history["val_psnr_model"], label="FSRCNN PSNR")
    ax2.set_title("PSNR Curve")
    ax2.set_xlabel("Epoch")
    ax2.set_ylabel("PSNR (dB)")
    ax2.legend()

    plt.tight_layout()
    plt.savefig(save_path, bbox_inches="tight")
    plt.show()
    plt.close(fig)


def tensor_to_np(t):
    return np.clip(t.detach().cpu().permute(1, 2, 0).numpy(), 0, 1)


def grayscale_np(img_np):
    if img_np.ndim == 3 and img_np.shape[2] == 3:
        return 0.299 * img_np[..., 0] + 0.587 * img_np[..., 1] + 0.114 * img_np[..., 2]
    return img_np


def detail_score(img_np):
    gray = grayscale_np(img_np)
    gy, gx = np.gradient(gray)
    return float(np.mean(np.abs(gx)) + np.mean(np.abs(gy)))


def center_crop_np(img_np, crop_size):
    h, w = img_np.shape[:2]
    crop = min(crop_size, h, w)
    top = max((h - crop) // 2, 0)
    left = max((w - crop) // 2, 0)
    return img_np[top:top + crop, left:left + crop]


def load_checkpoint_if_exists():
    checkpoint_path = os.path.join(SAVE_DIR, "fsrcnn_checkpoint.pth")
    best_model_path = os.path.join(SAVE_DIR, "fsrcnn_best.pth")

    history = {"train_loss": [], "val_loss": [], "val_psnr_model": [], "val_psnr_bicubic": []}
    best_psnr = -float("inf")
    start_epoch = 0

    if RESUME_TRAINING and os.path.exists(checkpoint_path):
        ckpt = torch.load(checkpoint_path, map_location=DEVICE)
        model.load_state_dict(ckpt["model_state_dict"])
        optimizer.load_state_dict(ckpt["optimizer_state_dict"])
        if "scheduler_state_dict" in ckpt:
            scheduler.load_state_dict(ckpt["scheduler_state_dict"])
        best_psnr = ckpt.get("best_psnr", best_psnr)
        history = ckpt.get("history", history)
        start_epoch = int(ckpt.get("epoch", 0))
        print(f"Resume training from epoch {start_epoch + 1}")
    elif RESUME_TRAINING and os.path.exists(best_model_path):
        model.load_state_dict(torch.load(best_model_path, map_location=DEVICE))
        print("Checkpoint not found, loaded best model weights only.")
    else:
        print("Start training from scratch.")

    return start_epoch, best_psnr, history


