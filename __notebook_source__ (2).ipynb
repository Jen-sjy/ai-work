class SRDataset(Dataset):
    def __init__(self, image_paths, patch_size=96, scale=2, training=True):
        self.image_paths = image_paths
        self.patch_size = patch_size
        self.scale = scale
        self.training = training
        self.to_tensor = transforms.ToTensor()

    def __len__(self):
        return len(self.image_paths)

    def _load_image(self, path):
        with Image.open(path) as img:
            return img.convert("RGB")

    def _mod_crop(self, img, scale):
        w, h = img.size
        w = max(scale, w - (w % scale))
        h = max(scale, h - (h % scale))
        return img.crop((0, 0, w, h))

    def __getitem__(self, idx):
        path = self.image_paths[idx]
        try:
            img = self._load_image(path)
            img = self._mod_crop(img, self.scale)
            w, h = img.size

            min_size = max(self.patch_size, self.scale * 8)
            if w < min_size or h < min_size:
                new_w = max(w, min_size)
                new_h = max(h, min_size)
                img = img.resize((new_w, new_h), Image.BICUBIC)
                img = self._mod_crop(img, self.scale)
                w, h = img.size

            if self.training:
                max_x = max(w - self.patch_size, 0)
                max_y = max(h - self.patch_size, 0)
                x = random.randint(0, max_x) if max_x > 0 else 0
                y = random.randint(0, max_y) if max_y > 0 else 0
                hr = img.crop((x, y, x + self.patch_size, y + self.patch_size))
                if hr.size != (self.patch_size, self.patch_size):
                    hr = hr.resize((self.patch_size, self.patch_size), Image.BICUBIC)

                if random.random() < 0.5:
                    hr = hr.transpose(Image.FLIP_LEFT_RIGHT)
                if random.random() < 0.5:
                    hr = hr.transpose(Image.FLIP_TOP_BOTTOM)
            else:
                crop_size = min(w, h, self.patch_size * 2)
                crop_size = max(crop_size - (crop_size % self.scale), self.scale)
                left = max((w - crop_size) // 2, 0)
                top = max((h - crop_size) // 2, 0)
                hr = img.crop((left, top, left + crop_size, top + crop_size))

            lr = hr.resize((max(hr.width // self.scale, 1), max(hr.height // self.scale, 1)), Image.BICUBIC)
            lr_up = lr.resize((hr.width, hr.height), Image.BICUBIC)

            lr_up = self.to_tensor(lr_up)
            hr = self.to_tensor(hr)
            return lr_up, hr, path
        except Exception as e:
            print(f"Skip bad sample: {path} | {type(e).__name__}: {e}")
            return None


def safe_collate(batch):
    batch = [item for item in batch if item is not None]
    if len(batch) == 0:
        return None
    lr_list, hr_list, path_list = zip(*batch)
    return torch.stack(lr_list, dim=0), torch.stack(hr_list, dim=0), list(path_list)


