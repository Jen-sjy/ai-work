def is_image_file(filename):
    exts = (".png", ".jpg", ".jpeg", ".bmp", ".webp")
    return filename.lower().endswith(exts)


def collect_image_paths(root_dir):
    image_paths = []
    for subdir, _, files in os.walk(root_dir):
        for file in files:
            if is_image_file(file):
                image_paths.append(os.path.join(subdir, file))
    image_paths.sort()
    return image_paths


def scan_kaggle_datasets(kaggle_input_root, hint=""):
    candidates = []
    if not os.path.isdir(kaggle_input_root):
        return candidates

    top_level_dirs = []
    for name in sorted(os.listdir(kaggle_input_root)):
        path = os.path.join(kaggle_input_root, name)
        if os.path.isdir(path):
            top_level_dirs.append(path)

    hint_lower = hint.strip().lower()

    for ds_root in top_level_dirs:
        image_count = 0
        sample_images = []
        for subdir, _, files in os.walk(ds_root):
            img_files = [f for f in files if is_image_file(f)]
            image_count += len(img_files)
            if img_files and len(sample_images) < 3:
                remain = 3 - len(sample_images)
                sample_images.extend([os.path.join(subdir, f) for f in img_files[:remain]])

        if image_count > 0:
            ds_name = os.path.basename(ds_root)
            hint_match = 1 if (hint_lower and hint_lower in ds_name.lower()) else 0
            candidates.append({
                "path": ds_root,
                "name": ds_name,
                "image_count": image_count,
                "hint_match": hint_match,
                "samples": sample_images,
            })

    candidates.sort(key=lambda x: (x["hint_match"], x["image_count"]), reverse=True)
    return candidates


def resolve_data_root(manual_root=None, kaggle_input_root="/kaggle/input", hint=""):
    if manual_root is not None and str(manual_root).strip() != "":
        manual_root = str(manual_root)
        if not os.path.isdir(manual_root):
            raise FileNotFoundError(f"MANUAL_DATA_ROOT 不存在: {manual_root}")
        print(f"Using MANUAL_DATA_ROOT: {manual_root}")
        return manual_root

    candidates = scan_kaggle_datasets(kaggle_input_root, hint=hint)
    if not candidates:
        raise FileNotFoundError(
            "没有在 /kaggle/input 下找到图片数据集。请先在 Kaggle 右侧 Add data 挂载数据集，"
            "或者手动设置 MANUAL_DATA_ROOT。"
        )

    print("Detected Kaggle image datasets:")
    for i, item in enumerate(candidates[:10], start=1):
        print(f"  [{i}] {item['name']} -> {item['image_count']} images")
        for s in item["samples"][:2]:
            print(f"      sample: {s}")

    selected = candidates[0]
    print("Selected DATA_ROOT:", selected["path"])
    if hint:
        if selected["hint_match"]:
            print(f"Hint matched: '{hint}'")
        else:
            print(f"Hint '{hint}' 未匹配到数据集名，已回退为图片数量最多的数据集。")
    return selected["path"]


def filter_valid_image_paths(image_paths, min_edge=16):
    valid_paths = []
    bad_paths = []
    for path in tqdm(image_paths, desc="Checking images"):
        try:
            with Image.open(path) as img:
                img = img.convert("RGB")
                w, h = img.size
                if min(w, h) >= min_edge:
                    valid_paths.append(path)
                else:
                    bad_paths.append(path)
        except Exception:
            bad_paths.append(path)
    return valid_paths, bad_paths


def split_paths(image_paths, val_ratio=0.1, seed=42):
    paths = list(image_paths)
    rng = random.Random(seed)
    rng.shuffle(paths)

    if len(paths) < 2:
        raise ValueError("有效图片数量不足，至少需要 2 张图片。")
    if len(paths) == 2:
        return [paths[0]], [paths[1]]

    val_len = max(1, int(len(paths) * val_ratio))
    val_len = min(val_len, len(paths) - 1)
    train_len = len(paths) - val_len
    return paths[:train_len], paths[train_len:]


def make_chunks(items, chunk_size):
    if chunk_size is None or chunk_size <= 0:
        return [items]
    return [items[i:i + chunk_size] for i in range(0, len(items), chunk_size)]


